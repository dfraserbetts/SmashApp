generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ItemTemplate {
  id                          String                           @id @map("ItemID")
  itemUrl                     String?                          @map("ItemUrl")
  createdAt                   DateTime                         @map("Timestamp")
  name                        String                           @map("ItemName")
  rarity                      ItemRarity                       @map("ItemRarity")
  level                       Int                              @map("ItemLevel")
  generalDescription          String                           @map("GeneralDescription")
  type                        ItemType                         @map("ItemType")
  size                        WeaponSize?                      @map("Size")
  meleeTargets                Int?                             @map("MeleeTargets")
  rangedTargets               Int?                             @map("RangedTargets")
  rangedDistanceFeet          Int?                             @map("RangedDistance")
  aoeCenterRangeFeet          Int?                             @map("AoECenterRange")
  aoeCount                    Int?                             @map("AoECount")
  aoeShape                    AoEShape?                        @map("AoEShape")
  aoeSphereRadiusFeet         Int?                             @map("AoESphereSize")
  aoeConeLengthFeet           Int?                             @map("AoEConeLength")
  aoeLineWidthFeet            Int?                             @map("AoELineWidth")
  aoeLineLengthFeet           Int?                             @map("AoELineLength")
  customWeaponAttributes      String?                          @map("CustomWeaponAttributes")
  armorLocation               ArmorLocation?                   @map("ArmorLocation")
  ppv                         Int?                             @map("PPV")
  mpv                         Int?                             @map("MPV")
  auraPhysical                Int?                             @map("Aura_Physical")
  auraMental                  Int?                             @map("Aura_Mental")
  customArmorAttributes       String?                          @map("CustomArmorAttributes")
  shieldHasAttack             Boolean?                         @map("ShieldHasAttack")
  customShieldAttributes      String?                          @map("CustomShieldAttributes")
  itemLocation                ItemLocation?                    @map("ItemLocation")
  customItemAttributes        String?                          @map("CustomItemAttributes")
  globalAttributeModifiers    Json?                            @default("[]") @map("GlobalAttributeModifiers")
  campaignId                  String                           @map("CampaignID")
  meleeDamageTypeIds          Int[]
  rangedDamageTypeIds         Int[]
  aoeDamageTypeIds            Int[]
  physicalStrength            Int?                             @map("PhysicalStrength")
  mentalStrength              Int?                             @map("MentalStrength")
  meleePhysicalStrength       Int?                             @map("meleePhysicalStrength")
  meleeMentalStrength         Int?                             @map("meleeMentalStrength")
  rangedPhysicalStrength      Int?                             @map("rangedPhysicalStrength")
  rangedMentalStrength        Int?                             @map("rangedMentalStrength")
  aoePhysicalStrength         Int?                             @map("aoePhysicalStrength")
  aoeMentalStrength           Int?                             @map("aoeMentalStrength")
  mythicLbPushTemplateId      String?                          @map("MythicLbPushTemplateID")
  mythicLbBreakTemplateId     String?                          @map("MythicLbBreakTemplateID")
  mythicLbTranscendTemplateId String?                          @map("MythicLbTranscendTemplateID")
  Campaign                    Campaign                         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  mythicLbPushTemplate        LimitBreakTemplate?              @relation("ItemTemplateMythicLbPushTemplate", fields: [mythicLbPushTemplateId], references: [id])
  mythicLbBreakTemplate       LimitBreakTemplate?              @relation("ItemTemplateMythicLbBreakTemplate", fields: [mythicLbBreakTemplateId], references: [id])
  mythicLbTranscendTemplate   LimitBreakTemplate?              @relation("ItemTemplateMythicLbTranscendTemplate", fields: [mythicLbTranscendTemplateId], references: [id])
  aoeDamageTypes              ItemTemplateAoEDamageType[]
  armorAttributes             ItemTemplateArmorAttribute[]
  attackEffectsAoE            ItemTemplateAttackEffectAoE[]
  attackEffectsMelee          ItemTemplateAttackEffectMelee[]
  attackEffectsRanged         ItemTemplateAttackEffectRanged[]
  defEffects                  ItemTemplateDefEffect[]
  meleeDamageTypes            ItemTemplateMeleeDamageType[]
  rangeCategories             ItemTemplateRangeCategory[]
  rangedDamageTypes           ItemTemplateRangedDamageType[]
  sanctifiedOptions           ItemTemplateSanctifiedOption[]
  shieldAttributes            ItemTemplateShieldAttribute[]
  tags                        ItemTag[]
  vrpEntries                  ItemTemplateVRPEntry[]
  wardingOptions              ItemTemplateWardingOption[]
  weaponAttributes            ItemTemplateWeaponAttribute[]

  @@index([campaignId])
  @@map("ItemTemplate")
}

model ItemTag {
  id             String       @id @default(cuid())
  itemTemplateId String
  tag            String
  createdAt      DateTime     @default(now())
  itemTemplate   ItemTemplate @relation(fields: [itemTemplateId], references: [id], onDelete: Cascade)

  @@unique([itemTemplateId, tag])
  @@index([tag])
  @@map("ItemTag")
}

model DamageType {
  id                Int                            @id @default(autoincrement())
  name              String                         @unique
  attackMode        String                         @default("PHYSICAL")
  attackEffectLinks AttackEffectDamageType[]
  aoeTemplates      ItemTemplateAoEDamageType[]
  meleeTemplates    ItemTemplateMeleeDamageType[]
  rangedTemplates   ItemTemplateRangedDamageType[]
  vrpEntries        ItemTemplateVRPEntry[]

  @@map("DamageType")
}

model AttackEffect {
  id              Int                              @id @default(autoincrement())
  name            String                           @unique
  tooltip         String?
  damageTypeLinks AttackEffectDamageType[]
  aoeTemplates    ItemTemplateAttackEffectAoE[]
  meleeTemplates  ItemTemplateAttackEffectMelee[]
  rangedTemplates ItemTemplateAttackEffectRanged[]

  @@map("AttackEffect")
}

model AttackEffectDamageType {
  attackEffectId Int
  damageTypeId   Int
  attackEffect   AttackEffect @relation(fields: [attackEffectId], references: [id], onDelete: Cascade)
  damageType     DamageType   @relation(fields: [damageTypeId], references: [id], onDelete: Cascade)

  @@id([attackEffectId, damageTypeId])
  @@index([damageTypeId])
  @@map("AttackEffectDamageType")
}

model DefEffect {
  id        Int                     @id @default(autoincrement())
  name      String                  @unique
  tooltip   String?
  templates ItemTemplateDefEffect[]

  @@map("DefEffect")
}

model WeaponAttribute {
  id                     Int                           @id @default(autoincrement())
  name                   String                        @unique
  tooltip                String?
  descriptorNotes        String?
  descriptorTemplate     String?
  pricingMode            String?
  pricingScalar          Float?
  placement              AttributePlacement            @default(TRAITS)
  requiresAoeShape       AoEShape?
  requiresRange          RangeCategory?
  requiresStrengthSource Boolean                       @default(false)
  requiresStrengthKind   StrengthKind?
  requiresRangeSelection Boolean                       @default(false)
  templates              ItemTemplateWeaponAttribute[]

  @@map("WeaponAttribute")
}

model ArmorAttribute {
  id                 Int                          @id @default(autoincrement())
  name               String                       @unique
  tooltip            String?
  descriptorNotes    String?
  descriptorTemplate String?
  pricingMode        String?
  pricingScalar      Float?
  placement          AttributePlacement           @default(TRAITS)
  requiresPvKind     StrengthKind?
  requiresPpv        Boolean                      @default(false)
  requiresMpv        Boolean                      @default(false)
  templates          ItemTemplateArmorAttribute[]

  @@map("ArmorAttribute")
}

model ShieldAttribute {
  id                 Int                           @id @default(autoincrement())
  name               String                        @unique
  tooltip            String?
  descriptorNotes    String?
  descriptorTemplate String?
  pricingMode        String?
  pricingScalar      Float?
  placement          AttributePlacement            @default(TRAITS)
  templates          ItemTemplateShieldAttribute[]

  @@map("ShieldAttribute")
}

model WardingOption {
  id        Int                         @id @default(autoincrement())
  name      String                      @unique
  templates ItemTemplateWardingOption[]

  @@map("WardingOption")
}

model SanctifiedOption {
  id        Int                            @id @default(autoincrement())
  name      String                         @unique
  templates ItemTemplateSanctifiedOption[]

  @@map("SanctifiedOption")
}

model ItemTemplateRangeCategory {
  itemTemplateId String
  rangeCategory  RangeCategory
  itemTemplate   ItemTemplate  @relation(fields: [itemTemplateId], references: [id], onDelete: Cascade)

  @@id([itemTemplateId, rangeCategory])
  @@map("ItemTemplateRangeCategory")
}

model ItemTemplateMeleeDamageType {
  itemTemplateId String
  damageTypeId   Int
  damageType     DamageType   @relation(fields: [damageTypeId], references: [id])
  itemTemplate   ItemTemplate @relation(fields: [itemTemplateId], references: [id], onDelete: Cascade)

  @@id([itemTemplateId, damageTypeId])
  @@map("ItemTemplateMeleeDamageType")
}

model ItemTemplateRangedDamageType {
  itemTemplateId String
  damageTypeId   Int
  damageType     DamageType   @relation(fields: [damageTypeId], references: [id])
  itemTemplate   ItemTemplate @relation(fields: [itemTemplateId], references: [id], onDelete: Cascade)

  @@id([itemTemplateId, damageTypeId])
  @@map("ItemTemplateRangedDamageType")
}

model ItemTemplateAoEDamageType {
  itemTemplateId String
  damageTypeId   Int
  damageType     DamageType   @relation(fields: [damageTypeId], references: [id])
  itemTemplate   ItemTemplate @relation(fields: [itemTemplateId], references: [id], onDelete: Cascade)

  @@id([itemTemplateId, damageTypeId])
  @@map("ItemTemplateAoEDamageType")
}

model ItemTemplateAttackEffectMelee {
  itemTemplateId String
  attackEffectId Int
  attackEffect   AttackEffect @relation(fields: [attackEffectId], references: [id])
  itemTemplate   ItemTemplate @relation(fields: [itemTemplateId], references: [id], onDelete: Cascade)

  @@id([itemTemplateId, attackEffectId])
  @@map("ItemTemplateAttackEffectMelee")
}

model ItemTemplateAttackEffectRanged {
  itemTemplateId String
  attackEffectId Int
  attackEffect   AttackEffect @relation(fields: [attackEffectId], references: [id])
  itemTemplate   ItemTemplate @relation(fields: [itemTemplateId], references: [id], onDelete: Cascade)

  @@id([itemTemplateId, attackEffectId])
  @@map("ItemTemplateAttackEffectRanged")
}

model ItemTemplateAttackEffectAoE {
  itemTemplateId String
  attackEffectId Int
  attackEffect   AttackEffect @relation(fields: [attackEffectId], references: [id])
  itemTemplate   ItemTemplate @relation(fields: [itemTemplateId], references: [id], onDelete: Cascade)

  @@id([itemTemplateId, attackEffectId])
  @@map("ItemTemplateAttackEffectAoE")
}

model ItemTemplateWeaponAttribute {
  itemTemplateId    String
  weaponAttributeId Int
  strengthSource    RangeCategory?
  rangeSource       RangeCategory?
  itemTemplate      ItemTemplate    @relation(fields: [itemTemplateId], references: [id], onDelete: Cascade)
  weaponAttribute   WeaponAttribute @relation(fields: [weaponAttributeId], references: [id])

  @@id([itemTemplateId, weaponAttributeId])
  @@map("ItemTemplateWeaponAttribute")
}

model ItemTemplateArmorAttribute {
  itemTemplateId   String
  armorAttributeId Int
  armorAttribute   ArmorAttribute @relation(fields: [armorAttributeId], references: [id])
  itemTemplate     ItemTemplate   @relation(fields: [itemTemplateId], references: [id], onDelete: Cascade)

  @@id([itemTemplateId, armorAttributeId])
  @@map("ItemTemplateArmorAttribute")
}

model ItemTemplateShieldAttribute {
  itemTemplateId    String
  shieldAttributeId Int
  itemTemplate      ItemTemplate    @relation(fields: [itemTemplateId], references: [id], onDelete: Cascade)
  shieldAttribute   ShieldAttribute @relation(fields: [shieldAttributeId], references: [id])

  @@id([itemTemplateId, shieldAttributeId])
  @@map("ItemTemplateShieldAttribute")
}

model ItemTemplateDefEffect {
  itemTemplateId String
  defEffectId    Int
  defEffect      DefEffect    @relation(fields: [defEffectId], references: [id])
  itemTemplate   ItemTemplate @relation(fields: [itemTemplateId], references: [id], onDelete: Cascade)

  @@id([itemTemplateId, defEffectId])
  @@map("ItemTemplateDefEffect")
}

model ItemTemplateWardingOption {
  itemTemplateId  String
  wardingOptionId Int
  itemTemplate    ItemTemplate  @relation(fields: [itemTemplateId], references: [id], onDelete: Cascade)
  wardingOption   WardingOption @relation(fields: [wardingOptionId], references: [id])

  @@id([itemTemplateId, wardingOptionId])
  @@map("ItemTemplateWardingOption")
}

model ItemTemplateSanctifiedOption {
  itemTemplateId     String
  sanctifiedOptionId Int
  itemTemplate       ItemTemplate     @relation(fields: [itemTemplateId], references: [id], onDelete: Cascade)
  sanctifiedOption   SanctifiedOption @relation(fields: [sanctifiedOptionId], references: [id])

  @@id([itemTemplateId, sanctifiedOptionId])
  @@map("ItemTemplateSanctifiedOption")
}

model ItemTemplateVRPEntry {
  id             Int           @id @default(autoincrement())
  itemTemplateId String
  effectKind     VRPEffectKind
  magnitude      Int
  damageTypeId   Int
  damageType     DamageType    @relation(fields: [damageTypeId], references: [id])
  itemTemplate   ItemTemplate  @relation(fields: [itemTemplateId], references: [id], onDelete: Cascade)

  @@index([itemTemplateId])
  @@map("ItemTemplateVRPEntry")
}

model ForgeConfigEntry {
  id        Int                 @id @default(autoincrement())
  category  ForgeConfigCategory
  selector1 String
  selector2 String?
  value     Float

  @@index([category, selector1, selector2])
  @@map("ForgeConfigEntry")
}

model ForgeCostEntry {
  id        Int               @id @default(autoincrement())
  category  ForgeCostCategory
  selector1 String
  selector2 String?
  selector3 String?
  value     Float
  notes     String?

  @@index([category, selector1, selector2, selector3])
  @@map("ForgeCostEntry")
}

model CombatTuning {
  id                                 String   @id @default(cuid())
  createdAt                          DateTime @default(now())
  updatedAt                          DateTime @updatedAt
  protectionK                        Int      @default(2)
  protectionS                        Int      @default(6)
  attackWeight                       Float    @default(1)
  guardWeight                      Float    @default(1)
  fortitudeWeight                    Float    @default(1)
  intellectWeight                    Float    @default(1)
  synergyWeight                      Float    @default(1)
  braveryWeight                      Float    @default(1)
  weaponSkillBraveryWeight           Float    @default(2)
  weaponSkillAttackWeight            Float    @default(1)
  weaponSkillBaselineOffset          Float    @default(1)
  weaponSkillScale                   Float    @default(1)
  armorSkillFortitudeWeight          Float    @default(2)
  armorSkillGuardWeight            Float    @default(1)
  armorSkillBaselineOffset           Float    @default(1)
  armorSkillScale                    Float    @default(1)
  willpowerSynergyWeight             Float    @default(2)
  willpowerBraveryWeight             Float    @default(1)
  willpowerBaselineOffset            Float    @default(1)
  willpowerScale                     Float    @default(1)
  minionTierMultiplier               Float    @default(1)
  soldierTierMultiplier              Float    @default(1.5)
  eliteTierMultiplier                Float    @default(2)
  bossTierMultiplier                 Float    @default(3)
  expectedPhysicalResilienceAt1      Float    @default(19)
  expectedPhysicalResiliencePerLevel Float    @default(1.5)
  expectedMentalPerseveranceAt1      Float    @default(19)
  expectedMentalPerseverancePerLevel Float    @default(1.5)

  expectedPoolMinionMultiplier  Float @default(1)
  expectedPoolSoldierMultiplier Float @default(1.5)
  expectedPoolEliteMultiplier   Float @default(2)
  expectedPoolBossMultiplier    Float @default(3)

  poolWeakerSideWeight Float @default(0.75)
  poolAverageWeight    Float @default(0.25)

  poolBelowExpectedMaxPenaltyShare Float @default(0.35)
  poolBelowExpectedScale           Float @default(0.25)
  poolAboveExpectedMaxBonusShare   Float @default(0.25)
  poolAboveExpectedScale           Float @default(0.4)

  @@map("CombatTuning")
}

model CombatTuningConfigSet {
  id          String                     @id @default(cuid())
  name        String
  slug        String                     @unique
  status      CombatTuningConfigStatus   @default(DRAFT)
  notes       String?                    @db.Text
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  activatedAt DateTime?
  entries     CombatTuningConfigEntry[]

  @@index([status, updatedAt])
  @@map("CombatTuningConfigSet")
}

model CombatTuningConfigEntry {
  id          String                @id @default(cuid())
  configSetId String
  configKey   String
  value       Float
  notes       String?               @db.Text
  sortOrder   Int                   @default(0)
  configSet   CombatTuningConfigSet @relation(fields: [configSetId], references: [id], onDelete: Cascade)

  @@unique([configSetId, configKey])
  @@index([configSetId, sortOrder])
  @@map("CombatTuningConfigEntry")
}

model PowerTuningConfigSet {
  id          String                   @id @default(cuid())
  name        String
  slug        String                   @unique
  status      PowerTuningConfigStatus  @default(DRAFT)
  notes       String?                  @db.Text
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  activatedAt DateTime?
  entries     PowerTuningConfigEntry[]

  @@index([status, updatedAt])
  @@map("PowerTuningConfigSet")
}

model PowerTuningConfigEntry {
  id          String               @id @default(cuid())
  configSetId String
  configKey   String
  value       Float
  notes       String?              @db.Text
  sortOrder   Int                  @default(0)
  configSet   PowerTuningConfigSet @relation(fields: [configSetId], references: [id], onDelete: Cascade)

  @@unique([configSetId, configKey])
  @@index([configSetId, sortOrder])
  @@map("PowerTuningConfigEntry")
}

model OutcomeNormalizationConfigSet {
  id          String                            @id @default(cuid())
  name        String
  slug        String                            @unique
  status      OutcomeNormalizationConfigStatus  @default(DRAFT)
  notes       String?                           @db.Text
  createdAt   DateTime                          @default(now())
  updatedAt   DateTime                          @updatedAt
  activatedAt DateTime?
  entries     OutcomeNormalizationConfigEntry[]

  @@index([status, updatedAt])
  @@map("OutcomeNormalizationConfigSet")
}

model OutcomeNormalizationConfigEntry {
  id          String                        @id @default(cuid())
  configSetId String
  configKey   String
  value       Float
  notes       String?                       @db.Text
  sortOrder   Int                           @default(0)
  configSet   OutcomeNormalizationConfigSet @relation(fields: [configSetId], references: [id], onDelete: Cascade)

  @@unique([configSetId, configKey])
  @@index([configSetId, sortOrder])
  @@map("OutcomeNormalizationConfigEntry")
}

model UserProfile {
  userId          String          @id @db.Uuid
  entitlementTier EntitlementTier @default(FREE)
  createdAt       DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime        @default(now()) @updatedAt @db.Timestamptz(6)
  isAdmin         Boolean         @default(false)

  @@map("UserProfile")
}

model Campaign {
  id                   String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  createdAt            DateTime       @default(now())
  name                 String
  ownerUserId          String
  descriptorVersionTag String         @default("v0")
  members              CampaignUser[]
  ItemTemplate         ItemTemplate[]
  monsters             Monster[]

  @@index([ownerUserId])
  @@map("Campaign")
}

model CampaignUser {
  campaignId String
  userId     String
  role       CampaignRole @default(PLAYER)
  createdAt  DateTime     @default(now())
  campaign   Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@id([campaignId, userId])
  @@index([userId])
  @@map("CampaignUser")
}

model DescriptorRule {
  id             Int             @id @default(autoincrement())
  versionTag     String
  scope          DescriptorScope @default(ANY)
  priority       Int             @default(0)
  isEnabled      Boolean         @default(true)
  conditionsJson Json            @default("{}")
  template       String
  notes          String?

  @@index([versionTag, scope, priority])
  @@map("DescriptorRule")
}

model Power {
  id                      String                  @id @default(cuid())
  monsterId               String?
  sourceType              PowerSourceType         @default(MONSTER_POWER)
  sortOrder               Int                     @default(0)
  name                    String
  description             String?                 @db.Text
  schemaVersion           Int                     @default(1)
  rulesVersion            String                  @default("v1")
  contentRevision         Int                     @default(1)
  previewRendererVersion  Int                     @default(1)
  status                  PowerStatus             @default(ACTIVE)
  descriptorChassis       DescriptorChassisType   @default(IMMEDIATE)
  descriptorChassisConfig Json                    @default("{}")
  chargeType              ChargeType?
  chargeTurns             Int?
  chargeBonusDicePerTurn  Int?
  counterMode             CounterMode             @default(NO)
  commitmentModifier      CommitmentModifier      @default(STANDARD)
  triggerMethod           TriggerMethod?
  attachedHostAnchorType  AttachedHostAnchorType?
  cooldownTurns           Int
  cooldownReduction       Int                     @default(0)
  lifespanType            PowerLifespanType       @default(NONE)
  lifespanTurns           Int?
  previewSummaryOverride  String?                 @db.Text
  meleeTargets            Int?
  rangedTargets           Int?
  rangedDistanceFeet      Int?
  aoeCenterRangeFeet      Int?
  aoeCount                Int?
  aoeShape                AoEShape?
  aoeSphereRadiusFeet     Int?
  aoeConeLengthFeet       Int?
  aoeLineWidthFeet        Int?
  aoeLineLengthFeet       Int?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @default(now()) @updatedAt
  monster                 Monster?                @relation(fields: [monsterId], references: [id], onDelete: Cascade)
  effectPackets           EffectPacket[]
  primaryDefenceGate      PrimaryDefenceGate?
  rangeCategories         PowerRangeCategory[]
  tags                    PowerTag[]
  limitBreakUsages        PowerLimitBreakUsage[]
  limitBreakProfiles      LimitBreakProfile[]

  @@index([monsterId, sortOrder])
  @@index([sourceType])
  @@map("Power")
}

model LimitBreakTemplate {
  id                      String                 @id @default(cuid())
  name                    String
  tooltip                 String?
  templateType            LimitBreakTemplateType
  tier                    LimitBreakTier
  thresholdPercent        Int
  description             String?                @db.Text
  intention               PowerIntention?
  itemType                String?
  monsterCategory         String?
  baseCostKey             String?
  baseCostParams          Json                   @default("{}")
  baseCostText            String?                @db.Text
  successEffectKey        String?
  successEffectParams     Json                   @default("{}")
  isPersistent            Boolean                @default(false)
  persistentCostTiming    String?
  persistentStateText     String?                @db.Text
  endConditionText        String?                @db.Text
  endCostKey              String?
  endCostParams           Json                   @default("{}")
  endCostText             String?                @db.Text
  failForwardEnabled      Boolean                @default(false)
  failForwardEffectKey    String?
  failForwardEffectParams Json                   @default("{}")
  failForwardCostAKey     String?
  failForwardCostBKey     String?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @default(now()) @updatedAt
  mythicLbPushItems       ItemTemplate[]         @relation("ItemTemplateMythicLbPushTemplate")
  mythicLbBreakItems      ItemTemplate[]         @relation("ItemTemplateMythicLbBreakTemplate")
  mythicLbTranscendItems  ItemTemplate[]         @relation("ItemTemplateMythicLbTranscendTemplate")

  @@index([templateType, tier])
  @@index([intention])
  @@index([itemType])
  @@map("LimitBreakTemplate")
}

model LimitBreakEffect {
  id                  String              @id @default(cuid())
  key                 String              @unique
  intentionGate       PowerIntention?
  params              Json                @default("{}")
  rulesText           String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @default(now()) @updatedAt
  failForwardProfiles LimitBreakProfile[] @relation("LimitBreakProfileFailForwardEffect")
  successProfiles     LimitBreakProfile[] @relation("LimitBreakProfileSuccessEffect")

  @@map("LimitBreakEffect")
}

model LimitBreakConsequence {
  id                       String              @id @default(cuid())
  key                      String              @unique
  params                   Json                @default("{}")
  rulesText                String?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @default(now()) @updatedAt
  baseConsequenceProfiles  LimitBreakProfile[] @relation("LimitBreakProfileBaseConsequence")
  failForwardCostAProfiles LimitBreakProfile[] @relation("LimitBreakProfileFailForwardCostA")
  failForwardCostBProfiles LimitBreakProfile[] @relation("LimitBreakProfileFailForwardCostB")

  @@map("LimitBreakConsequence")
}

model LimitBreakProfile {
  id                  String                 @id @default(cuid())
  powerId             String
  tier                LimitBreakTier
  name                String
  thresholdPercent    Int
  baseConsequenceId   String
  successEffectId     String
  failForwardEffectId String?
  failForwardCostAId  String?
  failForwardCostBId  String?
  isEnabled           Boolean                @default(true)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @default(now()) @updatedAt
  power               Power                  @relation(fields: [powerId], references: [id], onDelete: Cascade)
  baseConsequence     LimitBreakConsequence  @relation("LimitBreakProfileBaseConsequence", fields: [baseConsequenceId], references: [id])
  failForwardCostA    LimitBreakConsequence? @relation("LimitBreakProfileFailForwardCostA", fields: [failForwardCostAId], references: [id])
  failForwardCostB    LimitBreakConsequence? @relation("LimitBreakProfileFailForwardCostB", fields: [failForwardCostBId], references: [id])
  failForwardEffect   LimitBreakEffect?      @relation("LimitBreakProfileFailForwardEffect", fields: [failForwardEffectId], references: [id])
  successEffect       LimitBreakEffect       @relation("LimitBreakProfileSuccessEffect", fields: [successEffectId], references: [id])

  @@unique([powerId, tier])
  @@index([tier])
  @@map("LimitBreakProfile")
}

model PowerLimitBreakUsage {
  id          String              @id @default(cuid())
  actorType   LimitBreakActorType
  actorId     String
  powerId     String
  usedAtLevel Int
  createdAt   DateTime            @default(now())
  power       Power               @relation(fields: [powerId], references: [id], onDelete: Cascade)

  @@unique([actorType, actorId, powerId, usedAtLevel])
  @@index([actorType, actorId])
  @@index([powerId])
  @@map("PowerLimitBreakUsage")
}

model Monster {
  id                            String                @id @default(cuid())
  createdAt                     DateTime              @default(now())
  updatedAt                     DateTime              @default(now()) @updatedAt
  name                          String
  imageUrl                      String?
  imagePosX                     Float                 @default(50)
  imagePosY                     Float                 @default(35)
  level                         Int
  tier                          MonsterTier
  legendary                     Boolean               @default(false)
  calculatorArchetype           String                @default("BALANCED")
  source                        MonsterSource         @default(CAMPAIGN)
  isReadOnly                    Boolean               @default(false)
  campaignId                    String?
  attackMode                    MonsterAttackMode     @default(NATURAL_WEAPON)
  equippedWeaponId              String?
  mainHandItemId                String?
  offHandItemId                 String?
  smallItemId                   String?
  // SC_SEPARATE_ARMOR_AND_ITEM_SLOTS_V2
  headArmorItemId               String?
  shoulderArmorItemId           String?
  torsoArmorItemId              String?
  legsArmorItemId               String?
  feetArmorItemId               String?
  headItemId                    String?
  neckItemId                    String?
  armsItemId                    String?
  beltItemId                    String?
  customNotes                   String?               @db.Text
  limitBreakName                String?               @db.Text
  limitBreakTier                LimitBreakTier?
  limitBreakTriggerText         String?               @db.Text
  limitBreakAttribute           CoreAttribute?
  limitBreakThresholdSuccesses  Int?
  limitBreakCostText            String?               @db.Text
  limitBreakEffectText          String?               @db.Text
  limitBreak2Name               String?               @db.Text
  limitBreak2Tier               LimitBreakTier?
  limitBreak2TriggerText        String?               @db.Text
  limitBreak2Attribute          CoreAttribute?
  limitBreak2ThresholdSuccesses Int?
  limitBreak2CostText           String?               @db.Text
  limitBreak2EffectText         String?               @db.Text
  physicalResilienceCurrent     Int
  physicalResilienceMax         Int
  mentalPerseveranceCurrent     Int
  mentalPerseveranceMax         Int
  physicalProtection            Int
  mentalProtection              Int
  naturalPhysicalProtection     Int                   @default(0)
  naturalMentalProtection       Int                   @default(0)
  attackDie                     DiceSize
  attackResistDie               Int                   @default(0)
  attackModifier                Int                   @default(0)
  guardDie                    DiceSize
  guardResistDie              Int                   @default(0)
  guardModifier               Int                   @default(0)
  fortitudeDie                  DiceSize
  fortitudeResistDie            Int                   @default(0)
  fortitudeModifier             Int                   @default(0)
  intellectDie                  DiceSize
  intellectResistDie            Int                   @default(0)
  intellectModifier             Int                   @default(0)
  synergyDie                    DiceSize
  synergyResistDie              Int                   @default(0)
  synergyModifier               Int                   @default(0)
  braveryDie                    DiceSize
  braveryResistDie              Int                   @default(0)
  braveryModifier               Int                   @default(0)
  weaponSkillValue              Int
  weaponSkillModifier           Int                   @default(0)
  armorSkillValue               Int
  armorSkillModifier            Int                   @default(0)
  Campaign                      Campaign?             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  tags                          MonsterTag[]
  traits                        MonsterTrait[]
  attacks                       MonsterAttack[]
  naturalAttack                 MonsterNaturalAttack?
  powers                        Power[]

  @@index([campaignId])
  @@index([source])
  @@map("Monster")
}

model MonsterTraitDefinition {
  id                   String           @id @default(cuid())
  name                 String           @unique
  effectText           String?          @db.Text
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @default(now()) @updatedAt
  isEnabled            Boolean          @default(true)
  source               MonsterSource    @default(CORE)
  isReadOnly           Boolean          @default(true)
  band                 MonsterTraitBand @default(STANDARD)
  physicalThreatWeight Float            @default(0)
  mentalThreatWeight   Float            @default(0)
  physicalSurvivabilityWeight Float      @default(0)
  mentalSurvivabilityWeight   Float      @default(0)
  survivabilityWeight  Float            @default(0)
  manipulationWeight   Float            @default(0)
  synergyWeight        Float            @default(0)
  mobilityWeight       Float            @default(0)
  presenceWeight       Float            @default(0)
  traits               MonsterTrait[]
  mechanicalEffects    MonsterTraitMechanicalEffect[]

  @@index([source, isEnabled])
  @@map("MonsterTraitDefinition")
}

model MonsterTraitMechanicalEffect {
  id                String                 @id @default(cuid())
  traitDefinitionId String
  sortOrder         Int                    @default(0)
  target            String
  operation         String                 @default("ADD")
  valueExpression   String
  traitDefinition   MonsterTraitDefinition @relation(fields: [traitDefinitionId], references: [id], onDelete: Cascade)

  @@index([traitDefinitionId, sortOrder])
  @@map("MonsterTraitMechanicalEffect")
}

model MonsterTag {
  id        String  @id @default(cuid())
  monsterId String
  tag       String
  monster   Monster @relation(fields: [monsterId], references: [id], onDelete: Cascade)

  @@unique([monsterId, tag])
  @@index([tag])
  @@map("MonsterTag")
}

model MonsterTrait {
  id                String                 @id @default(cuid())
  monsterId         String
  sortOrder         Int                    @default(0)
  traitDefinitionId String
  monster           Monster                @relation(fields: [monsterId], references: [id], onDelete: Cascade)
  trait             MonsterTraitDefinition @relation(fields: [traitDefinitionId], references: [id], onDelete: Restrict)

  @@unique([monsterId, traitDefinitionId])
  @@index([monsterId, sortOrder])
  @@map("MonsterTrait")
}

model MonsterNaturalAttack {
  id           String  @id @default(cuid())
  monsterId    String  @unique
  attackName   String
  attackConfig Json    @default("{}")
  monster      Monster @relation(fields: [monsterId], references: [id], onDelete: Cascade)

  @@map("MonsterNaturalAttack")
}

model MonsterAttack {
  id               String                 @id @default(cuid())
  monsterId        String
  sortOrder        Int                    @default(0)
  attackMode       MonsterAttackEntryMode
  attackName       String?
  attackConfig     Json?
  equippedWeaponId String?
  monster          Monster                @relation(fields: [monsterId], references: [id], onDelete: Cascade)

  @@unique([monsterId, sortOrder])
  @@index([monsterId, sortOrder])
  @@map("MonsterAttack")
}

model PowerRangeCategory {
  powerId       String
  rangeCategory RangeCategory
  power         Power         @relation(fields: [powerId], references: [id], onDelete: Cascade)

  @@id([powerId, rangeCategory])
  @@map("PowerRangeCategory")
}

model EffectPacket {
  id                     String                              @id @default(cuid())
  powerId                String
  packetIndex            Int                                 @default(0)
  hostility              PacketHostility
  intention              PowerIntention
  specific               String?
  diceCount              Int
  potency                Int
  effectTimingType       EffectTimingType
  effectTimingTurns      Int?
  effectDurationType     EffectDurationType
  effectDurationTurns    Int?
  dealsWounds            Boolean                             @default(false)
  woundChannel           WoundChannel?
  targetedAttribute      CoreAttribute?
  applicationModeKey     String?
  resolutionOrigin       ResolutionOrigin                    @default(CASTER)
  applyTo                EffectPacketApplyTo?
  triggerConditionText   String?
  detailsJson            Json                                @default("{}")
  power                  Power                               @relation(fields: [powerId], references: [id], onDelete: Cascade)
  localTargetingOverride EffectPacketLocalTargetingOverride?

  @@index([powerId, packetIndex])
  @@map("EffectPacket")
}

model EffectPacketLocalTargetingOverride {
  packetId            String       @id
  meleeTargets        Int?
  rangedTargets       Int?
  rangedDistanceFeet  Int?
  aoeCenterRangeFeet  Int?
  aoeCount            Int?
  aoeShape            AoEShape?
  aoeSphereRadiusFeet Int?
  aoeConeLengthFeet   Int?
  aoeLineWidthFeet    Int?
  aoeLineLengthFeet   Int?
  packet              EffectPacket @relation(fields: [packetId], references: [id], onDelete: Cascade)

  @@map("EffectPacketLocalTargetingOverride")
}

model PrimaryDefenceGate {
  powerId             String                   @id
  sourcePacketIndex   Int                      @default(0)
  gateResult          PrimaryDefenceGateResult
  protectionChannel   ProtectionChannel?
  resistAttribute     CoreAttribute?
  hostileEntryPattern HostileEntryPattern?
  resolutionSource    GateResolutionSource     @default(INFERRED)
  power               Power                    @relation(fields: [powerId], references: [id], onDelete: Cascade)

  @@map("PrimaryDefenceGate")
}

model PowerTag {
  id        String   @id @default(cuid())
  powerId   String
  tag       String
  createdAt DateTime @default(now())
  power     Power    @relation(fields: [powerId], references: [id], onDelete: Cascade)

  @@unique([powerId, tag])
  @@index([tag])
  @@map("PowerTag")
}

